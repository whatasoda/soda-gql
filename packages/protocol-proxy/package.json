{
  "name": "@soda-gql/protocol-proxy",
  "version": "0.14.1",
  "description": "Thin proxy binaries for soda-gql LSP — resolves project-local @soda-gql/lsp at runtime",
  "type": "module",
  "private": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "author": {
    "name": "Shota Hatada",
    "email": "shota.hatada@whatasoda.me",
    "url": "https://github.com/whatasoda"
  },
  "keywords": [
    "soda-gql",
    "lsp",
    "language-server",
    "proxy"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/whatasoda/soda-gql.git",
    "directory": "packages/protocol-proxy"
  },
  "homepage": "https://github.com/whatasoda/soda-gql#readme",
  "bugs": {
    "url": "https://github.com/whatasoda/soda-gql/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "soda-gql-lsp-proxy": "./dist/lsp-bin.cjs",
    "soda-gql-lsp-cli": "./dist/cli-bin.cjs"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1"
  }
}
