{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "customConditions": ["@soda-gql"]
  },
  "include": [
    "fixtures/**/*.ts",
    "graphql-system/index.ts",
    "graphql-system/_internal.ts",
    "graphql-system/_internal-injects.ts",
    "schemas/**/*.ts"
  ],
  "exclude": [
    "graphql-system/*.cjs",
    "fixtures/**/fragment-in-fragment.ts",
    "fixtures/**/basic-spread.ts",
    "fixtures/**/attach-chaining.ts",
    "fixtures/**/operations.ts",
    "fixtures/**/imported-binding-refs.ts",
    "fixtures/**/imported-slice-refs.ts",
    "fixtures/**/namespace-imports.ts",
    "fixtures/**/nested-namespace-deps.ts",
    "fixtures/**/top-level-with-metadata.ts",
    "fixtures/**/nested-create.ts",
    "fixtures/**/multiple-fragments.ts",
    "fixtures/**/local-and-imported-deps.ts"
  ]
}
